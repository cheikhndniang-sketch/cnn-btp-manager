# ==========================================================================
# CNN-BTPManager-Pro — Variables d'environnement (exemple)
# Copiez ce fichier vers backend/.env.local et frontend/.env.local
# ==========================================================================

# --- Backend (backend/.env.local) ---
DATABASE_URL="postgresql://cnn:cnn_secret@localhost:5544/cnn_btp"
JWT_SECRET="dev-secret-change-in-production-minimum-256-bits"
JWT_REFRESH_SECRET="dev-refresh-secret-different-from-jwt-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12
THROTTLE_TTL=60
THROTTLE_LIMIT=100
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"

# --- Frontend (frontend/.env.local) ---
VITE_API_URL="http://localhost:3000/v1"
VITE_APP_NAME="CNN-BTPManager Pro"
