// CNN-BTPManager-Pro — Schéma Prisma Phase 1
// CSE Immobilier — Reconstruction du Marché Sandaga

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DIRECTEUR_PROJET
  DIRECTEUR_TRAVAUX
  CONDUCTEUR_TRAVAUX
}

enum SiteStatus {
  ACTIVE
  ARCHIVED
  COMPLETED
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
  BLOCKED
}

model User {
  id                 String    @id @default(uuid())
  username           String    @unique
  passwordHash       String
  email              String?   @unique
  name               String
  role               Role      @default(CONDUCTEUR_TRAVAUX)
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  lastLogin          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  siteMembers   SiteMember[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
  documents     Document[]

  @@index([username])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Site {
  id             String     @id @default(uuid())
  reference      String     @unique
  name           String
  location       String?
  marcheHt          BigInt
  tvaRate           Decimal   @default(0.18) @db.Decimal(5, 4)
  tauxRg            Decimal   @default(0.05) @db.Decimal(5, 4)
  avanceForfaitaire BigInt    @default(0)
  startDate         DateTime  @db.Date
  endDatePlanned    DateTime? @db.Date
  status            SiteStatus @default(ACTIVE)
  description       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  members       SiteMember[]
  lots          Lot[]
  situations    Situation[]
  sousTraitants SousTraitant[]
  contratsst    ContratST[]
  situationsST  SituationST[]
  documents     Document[]
  travauxSupp   TravauxSupp[]
  rapports      RapportChantier[]
  avenants      Avenant[]
  ouvriers      Ouvrier[]
  pointages     Pointage[]

  @@index([status])
}

model Lot {
  id              String    @id @default(uuid())
  siteId          String
  code            String
  name            String
  description     String?
  weight          Int       @default(1)
  position        Int       @default(0)
  montantMarcheHt BigInt    @default(0)
  startDate       DateTime? @db.Date
  endDate         DateTime? @db.Date
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  site       Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  tasks      Task[]
  sitLignes  SituationLigne[]
  contratsst ContratST[]
  travauxSupp TravauxSupp[]

  @@unique([siteId, code])
  @@index([siteId])
}

model Task {
  id          String     @id @default(uuid())
  lotId       String
  name        String
  description String?
  progressPct Int        @default(0)
  status      TaskStatus @default(NOT_STARTED)
  weight      Int        @default(1)
  position    Int        @default(0)
  startDate   DateTime?  @db.Date
  endDate     DateTime?  @db.Date
  mppUid      Int? // UID d'origine MS Project (pour résoudre les dépendances à l'import)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  lot          Lot              @relation(fields: [lotId], references: [id], onDelete: Cascade)
  predecessors TaskDependency[] @relation("DepSuccessor")
  dependents   TaskDependency[] @relation("DepPredecessor")

  @@index([lotId])
}

enum DependencyType {
  FS // Fin → Début (Finish-to-Start)
  SS // Début → Début (Start-to-Start)
  FF // Fin → Fin (Finish-to-Finish)
  SF // Début → Fin (Start-to-Finish)
}

model TaskDependency {
  id            String         @id @default(uuid())
  successorId   String
  predecessorId String
  type          DependencyType @default(FS)
  lagDays       Int            @default(0)

  successor   Task @relation("DepSuccessor", fields: [successorId], references: [id], onDelete: Cascade)
  predecessor Task @relation("DepPredecessor", fields: [predecessorId], references: [id], onDelete: Cascade)

  @@unique([successorId, predecessorId])
  @@index([successorId])
  @@index([predecessorId])
}

model SiteMember {
  id       String   @id @default(uuid())
  siteId   String
  userId   String
  role     Role
  joinedAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
}

enum SituationStatus {
  BROUILLON
  VALIDEE
  PAYEE
}

model Situation {
  id           String          @id @default(uuid())
  siteId       String
  numero       Int
  periode      String          // format "2025-01"
  dateEmission    DateTime        @db.Date
  status          SituationStatus @default(BROUILLON)
  deductionAvance BigInt          @default(0)
  notes           String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  site   Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  lignes SituationLigne[]

  @@unique([siteId, numero])
  @@index([siteId])
}

model SituationLigne {
  id              String   @id @default(uuid())
  situationId     String
  lotId           String
  avancementCumul Decimal  @default(0) @db.Decimal(5, 2)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  situation Situation @relation(fields: [situationId], references: [id], onDelete: Cascade)
  lot       Lot       @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@unique([situationId, lotId])
  @@index([situationId])
  @@index([lotId])
}

// ── Documents ─────────────────────────────────────────────────────────

enum DocCategorie {
  PV
  COMPTE_RENDU
  ATTACHEMENT
  FACTURE
  PLAN
  PHOTO
  CONTRAT
  COURRIER
  AUTRE
}

model Document {
  id          String       @id @default(uuid())
  siteId      String
  uploadedBy  String
  nom         String
  categorie   DocCategorie @default(AUTRE)
  mimetype    String
  taille      Int
  contenu     Bytes
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [uploadedBy], references: [id])

  @@index([siteId, categorie])
  @@index([siteId, createdAt])
}

// ── Sous-traitance ────────────────────────────────────────────────────

enum ContratSTStatus {
  ACTIF
  TERMINE
  RESILIE
}

enum SituationSTStatus {
  BROUILLON
  VALIDEE
  PAYEE
}

model SousTraitant {
  id        String      @id @default(uuid())
  siteId    String
  nom       String
  contact   String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  site     Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  contrats ContratST[]

  @@index([siteId])
}

model ContratST {
  id                String          @id @default(uuid())
  siteId            String
  sousTraitantId    String
  lotId             String?
  reference         String
  intitule          String
  montantHt         BigInt          @default(0)
  tvaRate           Decimal         @default(0.18) @db.Decimal(5, 4)
  tauxRg            Decimal         @default(0.05) @db.Decimal(5, 4)
  avanceForfaitaire BigInt          @default(0)
  status            ContratSTStatus @default(ACTIF)
  startDate         DateTime?       @db.Date
  endDate           DateTime?       @db.Date
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  site         Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sousTraitant SousTraitant  @relation(fields: [sousTraitantId], references: [id])
  lot          Lot?          @relation(fields: [lotId], references: [id], onDelete: SetNull)
  situations   SituationST[]

  @@index([siteId])
  @@index([sousTraitantId])
}

model SituationST {
  id               String            @id @default(uuid())
  contratId        String
  siteId           String
  numero           Int
  periode          String
  dateEmission     DateTime          @db.Date
  status           SituationSTStatus @default(BROUILLON)
  montantHtPeriode BigInt            @default(0)
  deductionAvance  BigInt            @default(0)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  contrat ContratST @relation(fields: [contratId], references: [id], onDelete: Cascade)
  site    Site      @relation(fields: [siteId], references: [id])

  @@unique([contratId, numero])
  @@index([contratId])
  @@index([siteId])
}

// ── Travaux supplémentaires ───────────────────────────────────────────

enum TSStatus {
  BROUILLON
  VALIDE
  FACTURE
  PAYE
}

model TravauxSupp {
  id          String   @id @default(uuid())
  siteId      String
  lotId       String?
  reference   String
  description String
  montantHt   BigInt   @default(0)
  tvaRate     Decimal  @default(0.18) @db.Decimal(5, 4)
  status      TSStatus @default(BROUILLON)
  dateNotif   DateTime? @db.Date
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  lot  Lot? @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([siteId])
  @@index([siteId, status])
}

// ── Journal de chantier ───────────────────────────────────────────

enum Meteo {
  SOLEIL
  NUAGEUX
  PLUIE
  ORAGE
}

model RapportChantier {
  id              String   @id @default(uuid())
  siteId          String
  date            DateTime @db.Date
  meteo           Meteo?
  effectif        Int      @default(0)
  travauxRealises String?
  materiaux       String?
  observations    String?
  incidents       String?
  redacteurId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, date])
  @@index([siteId])
}

// ── Avenants au marché ────────────────────────────────────────────

model Avenant {
  id              String    @id @default(uuid())
  siteId          String
  numero          Int
  objet           String
  montantHt       BigInt    @default(0)
  dateNotif       DateTime  @db.Date
  dateApprobation DateTime? @db.Date
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, numero])
  @@index([siteId])
}

// ── Suivi effectif & salaires ─────────────────────────────────────────

enum QualificationOuvrier {
  MANOEUVRE
  OUVRIER_SPECIALISE
  CHEF_EQUIPE
  TECHNICIEN
  AGENT_MAITRISE
  INGENIEUR
  AUTRE
}

model Ouvrier {
  id             String               @id @default(uuid())
  siteId         String
  nom            String
  prenom         String?
  fonction       String?
  qualification  QualificationOuvrier @default(MANOEUVRE)
  tauxJournalier BigInt               @default(0)
  dateEntree     DateTime             @db.Date
  dateSortie     DateTime?            @db.Date
  actif          Boolean              @default(true)
  telephone      String?
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  site      Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pointages Pointage[]

  @@index([siteId])
  @@index([siteId, actif])
}

model Pointage {
  id        String   @id @default(uuid())
  ouvrierId String
  siteId    String
  date      DateTime @db.Date
  present   Boolean  @default(true)
  heures    Decimal  @default(8) @db.Decimal(4, 1)
  notes     String?
  createdAt DateTime @default(now())

  ouvrier Ouvrier @relation(fields: [ouvrierId], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([ouvrierId, date])
  @@index([siteId, date])
  @@index([ouvrierId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entity, entityId])
}
